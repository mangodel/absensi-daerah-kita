{
  "name": "SyncState",
  "type": "object",
  "properties": {
    "sync_token": {
      "type": "string",
      "description": "Token sinkronisasi Google Calendar (untuk incremental sync)"
    },
    "service_type": {
      "type": "string",
      "default": "googlecalendar",
      "description": "Jenis service yang di-sync"
    },
    "last_synced": {
      "type": "string",
      "description": "Timestamp sync terakhir (ISO string)"
    }
  }
}